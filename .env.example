# PostgreSQL connection string.
# Railway will provide this when a Postgres service is attached.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/raidguild_calendar

# Static bearer token for /api/agent/* endpoints.
# Generate a long random value for real deployments.
AGENT_API_TOKEN=replace-with-long-random-token

# Public display name used in the app chrome.
NEXT_PUBLIC_APP_NAME=Raid Guild Content Calendar
